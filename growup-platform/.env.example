# ============================================================
# GrowUp Agency — Environment Variables Reference
# ============================================================
# احتفظ بهذا الملف مرجعياً — لا تضعه في أي مكان عام
# Keep this as reference only — never commit actual secrets

# Supabase — من Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.public_key_here

# Supabase Service Role Key — سري جداً، فقط في Edge Functions، ليس في HTML
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.secret_key_here

# Resend — لتسليم الإيميلات (للاشتراك: resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Payload Encryption Key — لتشفير محتوى التسليم (استخدم أي نص عشوائي طويل)
PAYLOAD_ENCRYPTION_KEY=your-random-encryption-key-min-32-chars
